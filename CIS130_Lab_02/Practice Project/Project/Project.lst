 00000000  B9 00000005			mov ecx, 5							; Initialize ecx (Extended Counter Register) as the counter for a loop with a value of 5. (Value decrements each loop till it gets to 0) ECX = 5
 00000005  BE 00000000			mov esi, 0							; Initialize esi (Extended Source Index) to keep track of indexing while inside the loop. ESI = 0
 0000000A  B8 00000000			mov	eax, 0							; Initialize eax (Extended Acumulator Register) with the value of 0 to keep track of the sum of. EAX = 0
					
