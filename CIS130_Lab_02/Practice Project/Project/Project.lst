 00000017  E2 F6			loop L1								; Let program know to repeat loop again until ecx = 0. ecx automatically decrements each loop.
 00000019  A3 00000014 R		mov sum, eax						; Move the value stored inside eax to the sum in memory. sum = eax (sum of array.)

