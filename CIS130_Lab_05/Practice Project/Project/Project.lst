				; --------------------------------------------------------------------------------------------------------------------------------------------------
 0000001C			sumIfPositive proc									; sumIfPositive procedure (function) starts here.
				;
				; Calculates the sum of the positive elements in an array. (32 bit integer - 4 bytes per element is hardcoded into loop used to calculate sum)
				; Recieves: ECX (number of elements), ESI (array base address)
				; Returns: EAX =  # of warm days.
				; Requires: ECX & ESI to be initialized before procedure is called to function properly.
				; --------------------------------------------------------------------------------------------------------------------------------------------------

 0000001C  B8 00000000		mov	eax, 0											; Initialize eax with the value of 0 to keep track of the total number of warm days. EAX = 0
 00000021  BB 00000000		mov ebx, 0											; Initialize ebx with the value of 0 to increment through the array while inside the loop. EBX = 0

 00000026			L1:													; Loop created to get sum of array. L1 acts as the label to let program know where loop starts.
					
 00000026  8B 3C 9E			mov edi, [esi + ebx * 4]						; Add the value stored in numbers[index value] to edi. (edi = eax + numbers[index])
 00000029  83 FF 00			cmp edi, 0										; Compare the value stored in edx to the value in edi. if (EDI (array value) == EDX (60))

 0000002C  7E 02			jle lessThanOrEqualTo							; Jump to "lessThanOrEqualTo" if EDI < EDX.

 0000002E  03 C7			add eax, edi									; Increment the value of eax whenever value of EDI > EDX.

 00000030			lessThanOrEqualTo:									; Jump to this point in code if EDI < EDX.

 00000030  43				inc ebx											; Increment the value of esi to cycle through array. (esi++)

 00000031  E2 F3		loop L1												; Let program know to repeat loop again until ecx = 0. ecx automatically decrements each loop.

 00000033  C3				ret												; return to main procedure (function).

 00000034			sumIfPositive endp									; sumArray procedure (function) ends here.








