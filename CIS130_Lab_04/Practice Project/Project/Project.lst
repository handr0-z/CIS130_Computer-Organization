				.386												; Target CPU (32-bit CPU)

				.model flat,stdcall

				.stack 4096											; Allocates stack space (4096 bytes) for program.

 00000000			.data												; Variables are declared past this point

 00000000 00000004			numbers dword 4, 8, 12, 16, 20					; variable used to store an array of elements.
	   00000008
	   0000000C
	   00000010
	   00000014
 00000014 00000000			sum dword 0										; variable used to store the sum.

				ExitProcess proto,dwExitCode:dword 

 00000000			.code												; Instructions go past this point

 00000000			main proc											; Main procedure (function) starts here.

 00000000  B9 00000005			mov ecx, LENGTHOF numbers						; (used in sumArray procedure) Initialize ecx as the counter for a loop with a value of the array length. ECX = 5
 00000005  BA 00000000 R		mov edx, OFFSET numbers							; (used in sumArray procedure) Initialize edx with the value of memory address for numbers array. EDX = numbers array address
					
 0000000A  E8 0000000C			call sumArray									; call sumArray procedure (function).

 0000000F  A3 00000014 R		mov sum, eax									; Move the value stored inside eax to the sum in memory. sum = eax (sum of array.)

					invoke ExitProcess,0							; Tell Operating System to terminate the program.

 0000001B			main endp											; Main procedure (function) ends here.







				; --------------------------------------------------------------------------------------------------------------------------------------------------
 0000001B			sumArray proc										; sumArray procedure (function) starts here.
				;
				; Calculates and returms the sum of an array (32 bit integer - 4 bytes per element is hardcoded into loop used to calculate sum)
				; Recieves: ECX (Loop Counter), EDX (Array Address)
				; Returns: EAX = sum
				; Requires: ECX & EDX to be initialized before procedure is called to function properly.
				; --------------------------------------------------------------------------------------------------------------------------------------------------

 0000001B  BE 00000000		mov esi, 0											; Initialize esi with a value of 0 to keep track of indexing while inside the loop. ESI = 0
 00000020  B8 00000000		mov	eax, 0											; Initialize eax with the value of 0 to keep track of the sum of the array. EAX = 0

 00000025			L1:													; Loop created to get sum of array. L1 acts as the label to let program know where loop starts.
					
 00000025  03 04 B2			add eax, [edx + esi * 4]						; Add the value stored in numbers[index value] to eax. (eax = eax + numbers[index])
 00000028  46				inc esi											; Increment the value of esi to cycle through array. (esi++)

 00000029  E2 FA		loop L1												; Let program know to repeat loop again until ecx = 0. ecx automatically decrements each loop.

 0000002B  C3				ret												; return to main procedure (function).

 0000002C			sumArray endp										; sumArray procedure (function) ends here.








				end main											; Code for "linker", lets program know the entry point is the main procedure (function)
